{
  "priority": 1,
  "request": {
    "method": "POST",
    "urlPath": "/partner/pix",
    "bodyPatterns": [
      {
        "matchesJsonPath": "$[?(@.pixKey == 'partner-error@pix.test')]"
      }
    ]
  },
  "response": {
    "status": 500,
    "fixedDelayMilliseconds": 2000,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "code": "PARTNER_INTERNAL_ERROR",
      "message": "Temporary partner failure"
    }
  }
}
