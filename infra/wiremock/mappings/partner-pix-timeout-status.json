{
  "priority": 1,
  "request": {
    "method": "POST",
    "urlPath": "/partner/pix",
    "bodyPatterns": [
      {
        "matchesJsonPath": "$[?(@.pixKey == 'partner-request-timeout@pix.test')]"
      }
    ]
  },
  "response": {
    "status": 408,
    "fixedDelayMilliseconds": 2000,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "code": "PARTNER_REQUEST_TIMEOUT",
      "message": "Partner request timed out"
    }
  }
}
