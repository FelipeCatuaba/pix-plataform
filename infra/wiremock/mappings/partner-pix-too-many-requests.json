{
  "priority": 1,
  "request": {
    "method": "POST",
    "urlPath": "/partner/pix",
    "bodyPatterns": [
      {
        "matchesJsonPath": "$[?(@.pixKey == 'partner-rate-limit@pix.test')]"
      }
    ]
  },
  "response": {
    "status": 429,
    "fixedDelayMilliseconds": 2000,
    "headers": {
      "Content-Type": "application/json",
      "Retry-After": "5"
    },
    "jsonBody": {
      "code": "PARTNER_RATE_LIMITED",
      "message": "Too many requests"
    }
  }
}
